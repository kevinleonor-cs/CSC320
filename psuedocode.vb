PROGRAM PrintPersonInfo
    CALLIT firstName AS String = "John"
    CALLIT lastName AS String = "Smith"
    CALLIT streetAddress AS String = "123 Main Street"
    CALLIT city AS String = "Springfield"
    CALLIT zipCode AS String = "12345"

    SHOWIT firstName
    SHOWIT lastName
    SHOWIT streetAddress
    SHOWIT city
    SHOWIT zipCode
END PROGRAM